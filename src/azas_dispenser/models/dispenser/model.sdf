<?xml version="1.0"?>
<sdf version="1.9">
  <model name="azas_dispenser">
    <pose>0 0 0 0 0 0</pose>
    <static>false</static>

    <link name="base_link">
      <pose>0 0 0.19 0 0 0</pose>
      <inertial>
        <mass>20.0</mass>
        <inertia>
          <ixx>0.20</ixx>
          <iyy>0.20</iyy>
          <izz>0.20</izz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <geometry>
          <box>
            <size>0.09 0.09 0.38</size>
          </box>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="base_visual">
        <geometry>
          <box>
            <size>0.09 0.09 0.38</size>
          </box>
        </geometry>
        <material>
          <ambient>0.86 0.86 0.82 1</ambient>
          <diffuse>0.86 0.86 0.82 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="pump_link">
      <pose>0 0 0.41 0 0 0</pose>
      <inertial>
        <mass>0.08</mass>
        <inertia>
          <ixx>0.00005</ixx>
          <iyy>0.00005</iyy>
          <izz>0.00005</izz>
        </inertia>
      </inertial>
      <collision name="pump_collision">
        <geometry>
          <box>
            <size>0.055 0.055 0.02</size>
          </box>
        </geometry>
      </collision>
      <visual name="pump_visual">
        <geometry>
          <box>
            <size>0.055 0.055 0.02</size>
          </box>
        </geometry>
        <material>
          <ambient>0.15 0.35 0.95 1</ambient>
          <diffuse>0.15 0.35 0.95 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="base_to_world" type="fixed">
      <parent>world</parent>
      <child>base_link</child>
    </joint>

    <joint name="pump_slide_joint" type="prismatic">
      <parent>base_link</parent>
      <child>pump_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.06</lower>
          <upper>0.0</upper>
          <effort>120</effort>
          <velocity>0.2</velocity>
        </limit>
        <dynamics>
          <spring_reference>0.0</spring_reference>
          <spring_stiffness>550.0</spring_stiffness>
          <damping>18.0</damping>
          <friction>0.5</friction>
        </dynamics>
      </axis>
    </joint>
  </model>
</sdf>
