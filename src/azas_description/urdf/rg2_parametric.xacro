<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!--
    Azas compatibility wrapper for the mesh-based OnRobot RG2FT description.

    Source model:
      https://github.com/shining-b-02/OnRobot-RG2FT-ROS
    The upstream visual/collision meshes are vendored under
      package://azas_description/meshes/onrobot_rg2ft

    This wrapper keeps the previous azas_rg2_parametric macro signature so the
    Doosan M0609 overlay can switch from the temporary box model to the mesh
    model without changing its xacro call sites.
  -->
  <xacro:include filename="$(find azas_description)/urdf/onrobot_rg2ft_mesh_macro.xacro"/>

  <xacro:macro
    name="azas_rg2_parametric"
    params="
      parent_link
      prefix:=rg2_
      mount_xyz:='0 0 0'
      mount_rpy:='0 0 0'
      body_length:=0.213
      body_width:=0.149
      body_thickness:=0.036
      total_stroke:=0.110
      mass:=0.78
      finger_joints_fixed:=true
      tcp_link_name:=gripper_tcp
      tcp_z_offset:=0.213">

    <xacro:onrobot_rg2ft
      prefix="${prefix}"
      parent="${parent_link}"
      hw_interface="hardware_interface/PositionJointInterface">
      <origin xyz="${mount_xyz}" rpy="${mount_rpy}"/>
    </xacro:onrobot_rg2ft>

    <link name="${prefix}tcp"/>
    <joint name="${prefix}tcp_joint" type="fixed">
      <origin xyz="0 0 ${tcp_z_offset}" rpy="0 0 0"/>
      <parent link="${prefix}quick_changer"/>
      <child link="${prefix}tcp"/>
    </joint>

    <link name="${tcp_link_name}"/>
    <joint name="${tcp_link_name}_joint" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="${prefix}tcp"/>
      <child link="${tcp_link_name}"/>
    </joint>
  </xacro:macro>
</robot>
